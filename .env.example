# MySQL connection string (US deployment; expand regions later)
# Example: mysql://user:password@127.0.0.1:3306/timescout
DATABASE_URL=

# Optional legacy source adapter. Not required for the current Reddit-focused demo.
# eBay Developer keys: https://developer.ebay.com/my/keys
EBAY_APP_ID=
EBAY_CERT_ID=

# Optional experimental source adapter. Not required for the current demo.
# Chrono24 via Retailed (https://app.retailed.io) — chrono24.com is
# Cloudflare-protected; this is a metered API used by `npm run ingest:chrono24`.
RETAILED_API_KEY=

# Optional experimental feed adapter. Not required for the current demo.
# Path to a Jomashop / CJ-style tab- or comma-separated product feed.
JOMASHOP_FEED_PATH=

# HTTPS URL to the same style feed (for Vercel cron / `runScheduledIngest`).
# Optional: `JOMASHOP_CRON_ENABLE=1` runs it from `/api/cron/ingest`.
JOMASHOP_FEED_URL=

# Set to `1` to include Jomashop in scheduled ingest (cron + `npm run dev:scheduler`).
JOMASHOP_CRON_ENABLE=

# If set (0–23), Jomashop runs only during that UTC hour (first ~20 min of the hour).
# Leave unset to run every ingest tick when `JOMASHOP_CRON_ENABLE=1` (can be heavy).
JOMASHOP_CRON_HOUR_UTC=

# Optional User-Agent for `JOMASHOP_FEED_URL` fetches.
# JOMASHOP_FEED_FETCH_UA=

# Comma-separated Chrono24 search queries for cron rotation (defaults built-in).
# CHRONO24_CRON_QUERIES=Rolex,Omega Speedmaster,Cartier

# Retailed pages per cron run when ingesting Chrono24 (default 1).
# CHRONO24_CRON_PAGES=1

# Reddit requires a descriptive User-Agent for unauthenticated JSON reads.
# Optional; the ingester has a sensible default.
REDDIT_USER_AGENT=

# Shared secret for cron-triggered API routes (ingest, rescue-prices).
# On Vercel, set this env var and Vercel Cron will send it as a Bearer token
# automatically. For external schedulers or curl, pass as ?secret=... or
# `Authorization: Bearer ...`.
CRON_SECRET=

# HTTP Basic Auth credentials for /admin/* routes.
# In development, unset values allow unauthenticated access.
# In production, both must be set or admin routes return 401.
ADMIN_BASIC_USER=
ADMIN_BASIC_PASS=

# OpenAI API key for AI-assisted condition / watch-type classification.
# Used as a fallback when regex parsers return null. Optional — without it,
# ingest falls back to regex-only behavior and the `--ai` flag is a no-op.
OPENAI_API_KEY=

# Model used for AI classification. Defaults to "gpt-4o-mini" if unset.
# Pin to a dated version (e.g. "gpt-4o-mini-2024-07-18") for stable behavior.
# OPENAI_CLASSIFY_MODEL=
